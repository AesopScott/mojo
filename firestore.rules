rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can read and write their own profile only
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Users can read their own purchases; only the backend webhook can write
    match /purchases/{purchaseId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow write: if false; // webhook endpoint writes via Admin SDK
    }

    // Product submissions: service account (PHP) writes via OAuth2-authenticated REST API
    // Rule set to 'if false' because OAuth2-authenticated REST API bypasses Firestore security rules
    match /product_submissions/{submissionId} {
      allow create, write: if false; // OAuth2-authenticated service account writes bypass this rule
      allow read: if false;           // admin read via portal (future)
    }
  }
}
